# Example env file (DO NOT put secrets in git)
JWT_SECRET=change-me-use-a-long-random-string

# ── Email verification (Resend) ───────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create
RESEND_API_KEY=re_your_api_key_here

# Sender address (must be verified in Resend dashboard)
RESEND_FROM_EMAIL=support@winjgm.com

# Displayed as sender name in the email
SMTP_FROM_NAME=Money Manager

# Frontend URL used in verification links (no trailing slash)
APP_URL=https://www.winjgm.com

# ── Cloudflare Turnstile (anti-bot) ──────────────────────────────────────────
# Get your keys at: https://dash.cloudflare.com → Turnstile
# Secret key goes here (never expose this to the frontend)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
